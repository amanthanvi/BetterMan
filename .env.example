# Legacy FastAPI backend (kept for local maintenance/tests)
# DATABASE_URL=postgresql+asyncpg://betterman:betterman@localhost:54320/betterman
# REDIS_URL=redis://localhost:6379/0
ENV=dev

# Public base URL for absolute links (optional)
PUBLIC_BASE_URL=http://localhost:8000

# Observability (optional, backend)
SENTRY_DSN=

# Proxy trust for accurate IP-based rate limiting (optional)
TRUSTED_PROXY_CIDRS=

# Convex-backed app runtime
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
CONVEX_SITE_URL=
BETTERMAN_DATASET_STAGE=prod

# Convex ingestion HTTP actions
CONVEX_HTTP_URL=
CONVEX_INGEST_SECRET=

# Observability (optional, Next.js)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
